<%= form_with model: @book, local: true do |f| %>
  <% if @book.errors.any? %>
    <div class="error_messages">
      <h3><%= @book.errors.count %> 件のエラーがあります:</h3>
      <ul>
        <% @book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <p>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </p>

  <p>
    <%= f.label :author, "著者" %><br>
    <%= f.text_field :author %>
  </p>

  <p>
    <%= f.label :url, "URL" %><br>
    <%= f.text_field :url %>
  </p>

  <p><%= f.submit %></p>
<% end %>